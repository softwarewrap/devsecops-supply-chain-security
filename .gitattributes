# Text files (normalize line endings)
* text=auto

# Markdown and documentation
*.md text
*.txt text
*.yaml text
*.yml text
*.json text
*.xml text
*.sh text
*.py text
*.js text
*.ts text

# Diagrams and images
*.svg text
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary

# Microsoft Office
*.doc binary
*.xls binary
*.ppt binary

# OpenDocument formats
*.odt binary
*.ods binary
*.odp binary

# Git Large File Storage (LFS)
*.pdf  filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.pptx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.vsdx filter=lfs diff=lfs merge=lfs -text

# Archives
*.zip binary
*.tar binary
*.gz binary
*.tgz binary
*.bz2 binary
*.7z binary

# Compiled artifacts
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
